# Mixpanel Service Account Credentials
# Create a Service Account in your Mixpanel workspace
# See: https://developer.mixpanel.com/reference/service-accounts
SERVICE_ACCOUNT_USER_NAME=your_service_account_username
SERVICE_ACCOUNT_PASSWORD=your_service_account_password

# Mixpanel Project ID
# Found in your Mixpanel project settings
DEFAULT_PROJECT_ID=your_mixpanel_project_id

# Mixpanel API Base URL
# Use https://eu.mixpanel.com/api for EU clusters
# Use https://mixpanel.com/api for US clusters (default)
MIXPANEL_API_BASE_URL=https://eu.mixpanel.com/api
